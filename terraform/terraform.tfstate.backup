    {
      "mode": "managed",
      "type": "aws_sfn_state_machine",
      "name": "pipeline",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "arn": "arn:aws:states:us-east-1:879584802537:stateMachine:music-streaming-pipeline",
            "creation_date": "2026-05-28T10:43:18Z",
            "definition": "{\"Comment\":\"Music Streaming ETL Pipeline — orchestrates 5 Glue jobs in sequence\",\"StartAt\":\"NormalizeInput\",\"States\":{\"AggregateKPIs\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"NotifyFailure\",\"ResultPath\":\"$.error\"}],\"Next\":\"LoadDynamoDB\",\"Parameters\":{\"JobName\":\"music-streaming-kpi-aggregation\"},\"Resource\":\"arn:aws:states:::glue:startJobRun.sync\",\"ResultPath\":\"$.kpiResult\",\"Type\":\"Task\"},\"ArchiveFiles\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"NotifyFailure\",\"ResultPath\":\"$.error\"}],\"Next\":\"PipelineSucceeded\",\"Parameters\":{\"JobName\":\"music-streaming-archive\"},\"Resource\":\"arn:aws:states:::glue:startJobRun.sync\",\"ResultPath\":\"$.archiveResult\",\"Type\":\"Task\"},\"AreThereStreams\":{\"Choices\":[{\"Next\":\"ValidateData\",\"NumericGreaterThan\":0,\"Variable\":\"$.streamsCheck.KeyCount\"}],\"Default\":\"NoStreamsToProcess\",\"Type\":\"Choice\"},\"CheckAlreadyRunning\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"NotifyFailure\",\"ResultPath\":\"$.error\"}],\"Next\":\"IsAnotherRunning\",\"Parameters\":{\"MaxResults\":2,\"StateMachineArn\":\"arn:aws:states:us-east-1:879584802537:stateMachine:music-streaming-pipeline\",\"StatusFilter\":\"RUNNING\"},\"Resource\":\"arn:aws:states:::aws-sdk:sfn:listExecutions\",\"ResultPath\":\"$.runningCheck\",\"Type\":\"Task\"},\"CheckCrawlerStatus\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"NotifyFailure\",\"ResultPath\":\"$.error\"}],\"Next\":\"IsCrawlerReady\",\"Parameters\":{\"Name\":\"music-streaming-raw-crawler\"},\"Resource\":\"arn:aws:states:::aws-sdk:glue:getCrawler\",\"ResultPath\":\"$.crawlerStatus\",\"Type\":\"Task\"},\"CheckStreamsExist\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"NotifyFailure\",\"ResultPath\":\"$.error\"}],\"Next\":\"AreThereStreams\",\"Parameters\":{\"Bucket\":\"music-streaming-raw-dev\",\"MaxKeys\":1,\"Prefix\":\"streams/\"},\"Resource\":\"arn:aws:states:::aws-sdk:s3:listObjectsV2\",\"ResultPath\":\"$.streamsCheck\",\"Type\":\"Task\"},\"IsAnotherRunning\":{\"Choices\":[{\"IsPresent\":true,\"Next\":\"WaitForPreviousRun\",\"Variable\":\"$.runningCheck.Executions[1]\"}],\"Default\":\"StartRawCrawler\",\"Type\":\"Choice\"},\"IsCrawlerReady\":{\"Choices\":[{\"Next\":\"CheckStreamsExist\",\"StringEquals\":\"READY\",\"Variable\":\"$.crawlerStatus.Crawler.State\"}],\"Default\":\"WaitForCrawler\",\"Type\":\"Choice\"},\"LoadDynamoDB\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"NotifyFailure\",\"ResultPath\":\"$.error\"}],\"Next\":\"StartCuratedCrawler\",\"Parameters\":{\"JobName\":\"music-streaming-dynamodb-loader\"},\"Resource\":\"arn:aws:states:::glue:startJobRun.sync\",\"ResultPath\":\"$.dynamoResult\",\"Type\":\"Task\"},\"NoStreamsToProcess\":{\"Type\":\"Succeed\"},\"NormalizeInput\":{\"Next\":\"CheckAlreadyRunning\",\"Parameters\":{},\"Type\":\"Pass\"},\"NotifyFailure\":{\"Next\":\"PipelineFailed\",\"Parameters\":{\"Message.$\":\"States.Format('PIPELINE FAILED\\n\\nError: {}\\nCause: {}\\n\\nStep Functions console (click the red execution):\\nhttps://us-east-1.console.aws.amazon.com/states/home?region=us-east-1#/statemachines\\n\\nGlue job run history (if a Glue job failed):\\nhttps://us-east-1.console.aws.amazon.com/glue/home?region=us-east-1#/etl/jobs', $.error.Error, $.error.Cause)\",\"Subject\":\"❌ Music Streaming Pipeline FAILED\",\"TopicArn\":\"arn:aws:sns:us-east-1:879584802537:music-streaming-pipeline-alerts\"},\"Resource\":\"arn:aws:states:::sns:publish\",\"ResultPath\":\"$.snsResult\",\"Type\":\"Task\"},\"PipelineFailed\":{\"Cause\":\"One or more pipeline steps failed — check CloudWatch logs and SNS alert for details\",\"Error\":\"PipelineError\",\"Type\":\"Fail\"},\"PipelineSucceeded\":{\"Type\":\"Succeed\"},\"StartCuratedCrawler\":{\"Catch\":[{\"ErrorEquals\":[\"Glue.CrawlerRunningException\"],\"Next\":\"ArchiveFiles\",\"ResultPath\":null},{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"ArchiveFiles\",\"ResultPath\":null}],\"Next\":\"ArchiveFiles\",\"Parameters\":{\"Name\":\"music-streaming-curated-crawler\"},\"Resource\":\"arn:aws:states:::aws-sdk:glue:startCrawler\",\"ResultPath\":null,\"Type\":\"Task\"},\"StartRawCrawler\":{\"Catch\":[{\"ErrorEquals\":[\"Glue.CrawlerRunningException\"],\"Next\":\"WaitForCrawler\",\"ResultPath\":null},{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"NotifyFailure\",\"ResultPath\":\"$.error\"}],\"Next\":\"WaitForCrawler\",\"Parameters\":{\"Name\":\"music-streaming-raw-crawler\"},\"Resource\":\"arn:aws:states:::aws-sdk:glue:startCrawler\",\"ResultPath\":null,\"Type\":\"Task\"},\"TransformData\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"NotifyFailure\",\"ResultPath\":\"$.error\"}],\"Next\":\"AggregateKPIs\",\"Parameters\":{\"JobName\":\"music-streaming-etl-transform\"},\"Resource\":\"arn:aws:states:::glue:startJobRun.sync\",\"ResultPath\":\"$.transformResult\",\"Type\":\"Task\"},\"ValidateData\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"NotifyFailure\",\"ResultPath\":\"$.error\"}],\"Next\":\"TransformData\",\"Parameters\":{\"JobName\":\"music-streaming-validation\"},\"Resource\":\"arn:aws:states:::glue:startJobRun.sync\",\"ResultPath\":\"$.validationResult\",\"Type\":\"Task\"},\"WaitForCrawler\":{\"Next\":\"CheckCrawlerStatus\",\"Seconds\":45,\"Type\":\"Wait\"},\"WaitForPreviousRun\":{\"Next\":\"CheckAlreadyRunning\",\"Seconds\":60,\"Type\":\"Wait\"}}}",
