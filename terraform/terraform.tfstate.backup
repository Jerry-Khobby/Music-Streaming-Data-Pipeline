            "id": "870176720",
            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"GlueJobControl\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"glue:StartJobRun\",\n        \"glue:GetJobRuns\",\n        \"glue:GetJobRun\",\n        \"glue:BatchStopJobRun\"\n      ],\n      \"Resource\": \"*\"\n    },\n    {\n      \"Sid\": \"GlueCrawlerControl\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"glue:StartCrawler\",\n        \"glue:GetCrawler\"\n      ],\n      \"Resource\": \"*\"\n    },\n    {\n      \"Sid\": \"SnsPublish\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"sns:Publish\",\n      \"Resource\": \"arn:aws:sns:us-east-1:879584802537:music-streaming-pipeline-alerts\"\n    },\n    {\n      \"Sid\": \"CloudWatchLogs\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"logs:UpdateLogDelivery\",\n        \"logs:PutResourcePolicy\",\n        \"logs:ListLogDeliveries\",\n        \"logs:GetLogDelivery\",\n        \"logs:DescribeResourcePolicies\",\n        \"logs:DescribeLogGroups\",\n        \"logs:DeleteLogDelivery\",\n        \"logs:CreateLogDelivery\"\n      ],\n      \"Resource\": \"*\"\n    },\n    {\n      \"Sid\": \"XRayTracing\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"xray:PutTraceSegments\",\n        \"xray:PutTelemetryRecords\",\n        \"xray:GetSamplingTargets\",\n        \"xray:GetSamplingRules\"\n      ],\n      \"Resource\": \"*\"\n    },\n    {\n      \"Sid\": \"SelfIntrospect\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"states:ListExecutions\",\n      \"Resource\": \"arn:aws:states:us-east-1:879584802537:stateMachine:music-streaming-pipeline\"\n    },\n    {\n      \"Sid\": \"S3ListStreams\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"s3:ListBucket\",\n      \"Resource\": \"arn:aws:s3:::music-streaming-raw-dev\",\n      \"Condition\": {\n        \"StringLike\": {\n          \"s3:prefix\": \"streams/*\"\n        }\n      }\n    }\n  ]\n}",
