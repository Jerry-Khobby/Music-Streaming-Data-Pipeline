# ── Secrets and credentials ──────────────────────────────────────────────────
.env
terraform/terraform.tfvars

# ── Terraform state (contains secrets — NEVER commit these) ──────────────────
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfplan

# ── Terraform local cache ─────────────────────────────────────────────────────
terraform/.terraform/
terraform/.terraform.lock.hcl

# ── Build artefacts (auto-generated by Terraform at apply time) ───────────────
terraform/monitoring_lib.zip
lambda/pipeline_notifier.zip

# ── Project data files ────────────────────────────────────────────────────────
data/

# ── Python virtualenv ─────────────────────────────────────────────────────────
venv/

# ── Office documents ──────────────────────────────────────────────────────────
*.docx
*.xlsx
*.pptx
